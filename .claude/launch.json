{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Gateway (dev)",
      "runtimeExecutable": "pnpm.CMD",
      "runtimeArgs": ["gateway:dev"],
      "port": 18789
    },
    {
      "name": "Gateway (watch)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["gateway:watch"],
      "port": 18789
    },
    {
      "name": "Control UI (Vite dev)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/ui.js", "dev"],
      "port": 5173
    },
    {
      "name": "Docs (Mintlify dev)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["docs:dev"],
      "port": 3000
    },
    {
      "name": "TUI (Terminal UI)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["tui:dev"],
      "port": null
    },
    {
      "name": "Docker Compose (full stack)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "port": 18789
    },
    {
      "name": "TAURA Dashboard",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http');h.createServer((q,r)=>{const o={hostname:'127.0.0.1',port:18789,path:q.url,method:q.method,headers:q.headers};const p=h.request(o,x=>{r.writeHead(x.statusCode,x.headers);x.pipe(r)});q.pipe(p);p.on('error',()=>{r.writeHead(502);r.end()})}).listen(5174,()=>console.log('Proxy on 5174'))"],
      "port": 5174
    },
    {
      "name": "TAURA Research Site",
      "runtimeExecutable": "node",
      "runtimeArgs": ["taura-research/new_page/serve.js", "3001"],
      "port": 3001
    }
  ]
}
