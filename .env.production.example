# ════════════════════════════════════════════════════════════
# TAURA Control — Production Environment Variables
# Copy to .env and fill ALL required values before deploy.
# ════════════════════════════════════════════════════════════

# ── Required: AI Keys ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENROUTER_API_KEY=sk-or-CHANGE_ME

# ── Required: Security ─────────────────────────────────────
# Gateway token for API write operations (generate a strong random string)
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_GENERATE_RANDOM_64_CHARS

# CORS whitelist (comma-separated origins)
TAURA_ALLOWED_ORIGINS=https://your-domain.com

# Auth bypass for local requests (set false in production!)
TAURA_ALLOW_LOCAL_BYPASS=false

# ── Required: Database ─────────────────────────────────────
SUPABASE_URL=http://your-supabase-host:54321
SUPABASE_KEY=eyJ_YOUR_SERVICE_ROLE_KEY_HERE

# ── Required: Postiz (Social Media) ───────────────────────
# IMPORTANT: Generate unique secrets — DO NOT use defaults!
POSTIZ_JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS
POSTIZ_DB_USER=postiz_prod
POSTIZ_DB_PASSWORD=CHANGE_ME_GENERATE_RANDOM_32_CHARS

# ── Optional: Gerador AI ──────────────────────────────────
# API key stays on backend — NEVER expose to frontend
GEMINI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS

# ── Optional: WhatsApp (Twilio fallback) ───────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ── Optional: Ports ────────────────────────────────────────
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
POSTIZ_PORT=5200
POSTIZ_API_PORT=3000
