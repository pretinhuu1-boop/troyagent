# ─── TAURA Research - Variaveis de Ambiente ──────────────
# Copie para .env:  cp .env.example .env

# ── API Keys da IA (pelo menos uma OBRIGATÓRIA) ─────────
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-XXXXX
# OpenRouter (para modelos alternativos)
OPENROUTER_API_KEY=sk-or-v1-XXXXX

# ── Gateway ──────────────────────────────────────────────
# Gere um token seguro: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_USE_openssl_rand_hex_32

# ── Twilio (WhatsApp) ────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX

# ── Supabase (banco de dados) ──────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ── Security: CORS origins (comma-separated) ──────────────
# Leave empty to allow only localhost + same-origin
TAURA_ALLOWED_ORIGINS=https://ecossistematroy.com
